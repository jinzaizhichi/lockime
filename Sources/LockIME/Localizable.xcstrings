          }
        }
      }
    },
    "Enable enhanced mode to add per-URL rules.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启增强模式后即可添加按网址的规则。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟增強模式後即可新增依網址的規則。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拡張モードを有効にすると、URLごとのルールを追加できます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez le mode avancé pour ajouter des règles par URL."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere den erweiterten Modus, um URL-spezifische Regeln hinzuzufügen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa el modo avanzado para añadir reglas por URL."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative o modo avançado para adicionar regras por URL."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите расширенный режим, чтобы добавлять правила для отдельных URL."
          }
        }
      }
    },
    "Per-URL rules work in Safari, Firefox, and Chromium-based browsers (Chrome, Edge, Brave, Arc, Vivaldi, Opera).": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按网址的规则适用于 Safari、Firefox 以及基于 Chromium 的浏览器（Chrome、Edge、Brave、Arc、Vivaldi、Opera）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依網址的規則適用於 Safari、Firefox 以及基於 Chromium 的瀏覽器（Chrome、Edge、Brave、Arc、Vivaldi、Opera）。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "URLごとのルールは Safari、Firefox、および Chromium 系ブラウザ（Chrome、Edge、Brave、Arc、Vivaldi、Opera）で動作します。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les règles par URL fonctionnent dans Safari, Firefox et les navigateurs basés sur Chromium (Chrome, Edge, Brave, Arc, Vivaldi, Opera)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "URL-Regeln funktionieren in Safari, Firefox und Chromium-basierten Browsern (Chrome, Edge, Brave, Arc, Vivaldi, Opera)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las reglas por URL funcionan en Safari, Firefox y navegadores basados en Chromium (Chrome, Edge, Brave, Arc, Vivaldi, Opera)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As regras por URL funcionam no Safari, no Firefox e em navegadores baseados em Chromium (Chrome, Edge, Brave, Arc, Vivaldi, Opera)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Правила для отдельных URL работают в Safari, Firefox и браузерах на базе Chromium (Chrome, Edge, Brave, Arc, Vivaldi, Opera)."
          }
        }
      }
    },
    "Stable ships from tagged releases. Beta tracks the nightly build (built automatically around 01:00 UTC) — newer features, but less tested.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "稳定版来自打标签（Tag）的正式发布。测试版（Beta）跟随每日构建（约 UTC 01:00 自动构建）——功能更新更快，但测试更少。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "穩定版來自打標籤（Tag）的正式發行。測試版（Beta）跟隨每日建置（約 UTC 01:00 自動建置）——功能更新更快，但測試較少。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安定版はタグ付きリリースから配信されます。ベータ版はナイトリービルド（UTC 1:00 頃に自動ビルド）を追跡します。新機能が早い反面、テストは少なめです。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La version stable provient des versions taguées. La bêta suit la build nightly (générée automatiquement vers 01h00 UTC) — fonctionnalités plus récentes, mais moins testées."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stable stammt aus getaggten Releases. Beta folgt dem Nightly-Build (automatisch gegen 01:00 UTC erstellt) – neuere Funktionen, aber weniger getestet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La versión estable proviene de lanzamientos etiquetados. La beta sigue la compilación nightly (generada automáticamente sobre las 01:00 UTC): funciones más nuevas, pero menos probadas."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A versão estável vem de lançamentos com tag. A beta acompanha a compilação noturna (gerada automaticamente por volta das 01:00 UTC) — recursos mais novos, mas menos testados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
