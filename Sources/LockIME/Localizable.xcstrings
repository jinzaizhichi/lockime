    "Couldn't check for updates. Please check your internet connection and try again later.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法检查更新。请检查网络连接，稍后再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法檢查更新。請檢查網路連線，稍後再試。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アップデートを確認できませんでした。インターネット接続を確認して、後でもう一度お試しください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
