  "strings": {
    "Lock to previous input source": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "锁定为上一个输入法"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "鎖定為上一個輸入法"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前の入力ソースにロック"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verrouiller sur la source de saisie précédente"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf vorherige Eingabequelle sperren"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloquear en la fuente de entrada anterior"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloquear na fonte de entrada anterior"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Блокировать на предыдущем источнике ввода"
          }
        }
      }
    },
    "Lock to next input source": {
