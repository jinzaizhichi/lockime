    "Act on whichever app is frontmost. Nothing happens if it has no rule.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "作用于当前最前台的应用。若该应用没有规则，则不发生任何变化。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "作用於目前最前台的 App。若該 App 沒有規則，則不會有任何變化。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最前面のアプリに作用します。ルールがなければ何も起こりません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Agit sur l’app au premier plan. Rien ne se passe si elle n’a pas de règle."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wirkt auf die jeweils vorderste App. Ohne Regel passiert nichts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actúa sobre la app en primer plano. No ocurre nada si no tiene ninguna regla."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Age sobre o app em primeiro plano. Nada acontece se ele não tiver uma regra."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Действует на активное приложение. Если у него нет правила, ничего не происходит."
          }
        }
      }
    },
    "Remove this app's rule": {
