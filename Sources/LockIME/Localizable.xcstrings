    },
    "This backup file is damaged and can't be read.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此备份文件已损坏，无法读取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此備份檔案已損毀，無法讀取。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このバックアップファイルは破損していて読み込めません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce fichier de sauvegarde est endommagé et illisible."
          }
        },
        "de": {
          "stringUnit": {
