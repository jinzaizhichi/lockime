    "Enhanced mode reads the active browser URL via Accessibility to apply per-URL rules. The core lock needs no permissions.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "增强模式通过辅助功能读取当前浏览器网址，以应用按网址的规则。核心锁定无需任何权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "增強模式透過輔助使用讀取目前瀏覽器網址，以套用按網址的規則。核心鎖定不需要任何權限。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拡張モードはアクセシビリティを使って現在のブラウザの URL を読み取り、URL 別ルールを適用します。コアのロックに権限は不要です。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode avancé lit l’URL du navigateur actif via l’accessibilité pour appliquer des règles par URL. Le verrouillage de base ne nécessite aucune autorisation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der erweiterte Modus liest die aktive Browser-URL über die Bedienungshilfen, um Regeln pro URL anzuwenden. Die Kernsperre benötigt keine Berechtigungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo avanzado lee la URL del navegador activo mediante accesibilidad para aplicar reglas por URL. El bloqueo básico no necesita permisos."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo avançado lê a URL do navegador ativo via acessibilidade para aplicar regras por URL. O bloqueio básico não precisa de permissões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расширенный режим читает URL активного браузера через универсальный доступ для применения правил по URL. Базовой блокировке разрешения не нужны."
          }
        }
      }
    },
