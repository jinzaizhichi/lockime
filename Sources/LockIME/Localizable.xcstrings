    "Current app": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前应用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前 App"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のアプリ"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "App actuelle"
          }
        },
        "de": {
